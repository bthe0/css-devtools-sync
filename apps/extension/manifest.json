{
  "manifest_version": 3,
  "name": "CSS DevTools Sync",
  "version": "0.1.0",
  "description": "Captures CSS/DOM edits made in Chrome DevTools and syncs them back to local source files via the apply engine embedded in your dev server (@css-sync/vite).",
  "minimum_chrome_version": "120",
  "permissions": ["debugger", "storage"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "action": {
    "default_title": "CSS DevTools Sync — autosave & sync",
    "default_popup": "popup.html"
  },
  "commands": {
    "sync-now": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Sync captured DevTools edits to source now"
    }
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
