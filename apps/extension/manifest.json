{
  "manifest_version": 3,
  "name": "CSS DevTools Sync",
  "version": "0.1.0",
  "description": "Captures CSS/DOM edits made in Chrome DevTools and syncs them back to local source files via the apply engine embedded in your dev server (@dev-sync/vite).",
  "minimum_chrome_version": "120",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "CSS DevTools Sync — autosave & sync",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "sync-now": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Sync captured DevTools edits to source now"
    }
  },
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content-script.js", "harness.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["harness-main.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "capture-core.js",
        "background/diff.js",
        "background/sourcemap-url.js"
      ],
      "matches": ["http://localhost/*", "http://127.0.0.1/*"]
    }
  ]
}
