# dev-sync apply engine — environment (@dev-sync/server reads process.env).
# Copy to .env. The server does NOT auto-load .env — export these in your shell
# or prefix the dev command, e.g.:
#   DEV_SYNC_WORKSPACE_ROOT=$PWD/apps/test-app pnpm --filter @dev-sync/server dev
# config.ts parses + validates all of this at startup and REFUSES to boot on any
# missing/invalid value (fail-fast).

# ── Required ─────────────────────────────────────────────────────────────────

# Filesystem jail root. Every write is confined under this directory (realpath-
# resolved). The server refuses to start if it is unset or not an existing dir.
#   DEV_SYNC_WORKSPACE_ROOT=/absolute/path/to/dev-sync/apps/test-app
DEV_SYNC_WORKSPACE_ROOT=

# ── Environment toggle ───────────────────────────────────────────────────────

# development (default) | test | production.
# In production the two guards below become REQUIRED (fail-closed) and
# LLM-assisted rule placement is disabled.
APP_ENV=development

# ── Required in production, optional in development ──────────────────────────

# Shared secret gating all writer routes (/apply, /describe, /verify, journal):
# when set, requests must carry a matching x-sync-token header (401 otherwise).
# Unset in dev → routes are open for convenience. MUST be set when
# APP_ENV=production or startup fails — an ungated writer is remote file write.
# Generate: `openssl rand -hex 32`
SYNC_TOKEN=

# Chrome extension id (32 lowercase a-p chars). CORS allows ONLY
# chrome-extension://<this id>. Unset in dev → any extension-shaped origin is
# accepted; in production it rejects every origin, so it is REQUIRED there.
# Find it at chrome://extensions with Developer mode on.
EXTENSION_ID=

# ── Optional ─────────────────────────────────────────────────────────────────

# Standalone server port (default 7777; the extension panel expects 7777).
# Unused in embedded/plugin mode (rides the dev server's own socket).
PORT=7777

# Enables LLM-assisted PLACEMENT of brand-new rules when candidate files tie
# (deterministic otherwise; never used for exact edits). Disabled when
# APP_ENV=production. Leave empty to disable.
ANTHROPIC_API_KEY=

# Workspace-relative stylesheet that promoted inline-style edits are written
# into as `.csync-* { ... }` rules; must already be imported globally by the
# app. Default: src/index.css.
DEV_SYNC_OVERRIDES_FILE=src/index.css

# Base dir for the append-only write journal (one JSONL per workspace),
# deliberately OUTSIDE the workspace jail. Unset → ~/.dev-sync/journal.
DEV_SYNC_JOURNAL_DIR=
