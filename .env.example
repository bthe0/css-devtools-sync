# css-devtools-sync server configuration (@css-sync/server reads process.env).
# Copy to .env — the server does NOT auto-load .env; export these in your shell
# or prefix the dev command, e.g.:
#   CSS_SYNC_WORKSPACE_ROOT=$PWD/apps/test-app pnpm --filter @css-sync/server dev

# REQUIRED. Absolute (or cwd-relative) directory the server is allowed to write
# to. Every file edit is jailed under this root (realpath-resolved). For the
# demo run-through, point it at the test app:
#   CSS_SYNC_WORKSPACE_ROOT=/absolute/path/to/css-devtools-sync/apps/test-app
CSS_SYNC_WORKSPACE_ROOT=

# Optional. Enables LLM-assisted placement of NEW css rules when the
# deterministic resolver finds more than one candidate file. Never used in
# production APP_ENV; never used for exact edits. Leave empty to disable.
ANTHROPIC_API_KEY=

# development | test | production. Defaults to development.
APP_ENV=development

# Server port. The extension panel expects 7777.
PORT=7777

# Optional. Locks CORS down to ONLY chrome-extension://<this id> (32 lowercase
# a-p characters — the id Chrome assigns your loaded/published extension).
# Recommended for any non-throwaway setup. When unset, chrome-extension://*
# origins are still accepted, but ONLY while APP_ENV!==production — an
# unconfigured production deployment accepts no chrome-extension origin at
# all (fail-closed). Find your id at chrome://extensions with Developer mode on.
EXTENSION_ID=

# Optional. When set, /apply and /verify require a matching x-sync-token
# request header, rejecting non-matching/missing tokens with 401. Recommended
# alongside EXTENSION_ID for defense in depth on any machine that isn't
# fully single-user. Leave empty to disable (default: no token required).
SYNC_TOKEN=
