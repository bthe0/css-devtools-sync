{
  "name": "css-devtools-sync",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm --filter \"./packages/*\" build && pnpm -r typecheck",
    "dev": "pnpm --filter @dev-sync/server dev",
    "test": "pnpm -r --filter=!@dev-sync/e2e test",
    "test:e2e": "pnpm --filter @dev-sync/e2e test"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  }
}
